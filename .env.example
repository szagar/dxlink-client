# dxlink-client configuration — copy to `.env` and fill in.
# Loaded by pydantic-settings (env_prefix DXLINK_). Real `.env` is gitignored.

# ── dxLink endpoint ───────────────────────────────────────────────────────
# Default is the dxfeed DEMO server (no credentials, delayed AAPL/EUR-USD; no
# option greeks). For the live TastyTrade feed, set this to the `dxlink-url`
# returned by GET /api-quote-tokens.
DXLINK_URL=wss://demo.dxfeed.com/market-data/dxlink-ws

# Quote token for authenticated endpoints (the `token` from /api-quote-tokens).
# Leave BLANK for the demo server (it authorizes anonymously).
DXLINK_TOKEN=

# Keepalive cadence (server keepaliveTimeout is 60s; 30s leaves margin).
DXLINK_KEEPALIVE_INTERVAL_S=30

# ── TastyTrade credentials (OPTIONAL) ─────────────────────────────────────
# Only needed if you use a TastyTrade token provider to mint DXLINK_TOKEN from
# a login. The core client does NOT read these — they are for a token-provider
# extra. Never commit real values.
TASTYTRADE_LOGIN=
TASTYTRADE_PASSWORD=
TASTYTRADE_API_BASE=https://api.tastytrade.com
